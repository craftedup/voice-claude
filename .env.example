# Voice Claude Configuration
# Copy this file to .env and fill in your API keys

# Eleven Labs API Key (required for TTS)
# Get one at: https://elevenlabs.io/
ELEVEN_API_KEY=your_elevenlabs_key_here

# Eleven Labs Voice ID (optional)
# Default is "Sarah" - browse voices at https://elevenlabs.io/voice-library
# ELEVEN_VOICE_ID=EXAVITQu4vr4xnSDxMaL
